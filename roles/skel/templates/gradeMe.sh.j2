#!/bin/bash

source starter/env

echo "Calificando en: ${PORT}"

GREEN='\033[0;32m'
RED='\033[0;31m'
NC='\033[0m' # No Color

BASE="http://localhost:${PORT}"

# Helper function to run a test
run_test() {
  local name="$1"
  local expected_status="$2"
  local expected_body_contains="$3"
  shift 3
  local curl_args=("$@")

  # Run curl: body in stdout, status code appended after a delimiter
  response=$(curl -s -w "|||%{http_code}" "${curl_args[@]}")
  body="${response%|||*}"
  status="${response##*|||}"

  # Check status code
  if [ "$status" -eq "$expected_status" ]; then
    status_ok=true
  else
    status_ok=false
  fi

  # Check body contains expected string (if provided)
  if [ -z "$expected_body_contains" ] || echo "$body" | grep -q "$expected_body_contains"; then
    body_ok=true
  else
    body_ok=false
  fi

  # Report
  if $status_ok && $body_ok; then
    echo -e "${GREEN}✓ PASS${NC} [$name] status=$status"
  else
    echo -e "${RED}✗ FAIL${NC} [$name]"
    $status_ok || echo "  Expected status $expected_status, got $status"
    $body_ok   || echo "  Body did not contain: '$expected_body_contains'"
    echo "  Body: $body"
  fi
}


run_test "GET /" 200 "Hola mundo" \
  curl -X GET "$BASE/"

# GET — expect 200 and a specific field in the JSON body
run_test "GET /posts/1" 200 '"userId": 1' \
  curl -X GET "$BASE/posts/1" -H "Accept: application/json"

# POST — send JSON body, expect 201 and the echoed title
run_test "POST /posts" 201 '"title": "foo"' \
  curl -X POST "$BASE/posts" \
    -H "Content-Type: application/json" \
    -d '{"title":"foo","body":"bar","userId":1}'

# 404 case
run_test "GET /posts/99999" 404 "" \
  curl -X GET "$BASE/posts/99999"
